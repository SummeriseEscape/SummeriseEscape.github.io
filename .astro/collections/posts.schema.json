{
  "$ref": "#/definitions/posts",
  "definitions": {
    "posts": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "date": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "updated": {
          "anyOf": [
            {
              "type": "string",
              "format": "date-time"
            },
            {
              "type": "string",
              "format": "date"
            },
            {
              "type": "integer",
              "format": "unix-time"
            }
          ]
        },
        "excerpt": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "poetry",
            "diary",
            "essay",
            "photography",
            "music"
          ]
        },
        "mood": {
          "type": "string",
          "enum": [
            "tranquil",
            "nostalgic",
            "dreamy",
            "warm",
            "melancholic"
          ]
        },
        "image": {
          "type": "string"
        },
        "imageAlt": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "draft": {
          "type": "boolean",
          "default": false
        },
        "featured": {
          "type": "boolean",
          "default": false
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "date",
        "excerpt",
        "category",
        "mood",
        "image",
        "imageAlt"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}