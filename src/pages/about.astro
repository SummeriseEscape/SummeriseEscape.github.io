---
import BaseLayout from '@/components/layout/BaseLayout.astro';
import GeometricCircle from '@/components/ui/GeometricCircle.astro';
---

<BaseLayout title="关于">
  <div style="max-width: 720px; margin-inline: auto; padding: 6rem 2rem 4rem; position: relative;">

    <!-- Decorative elements -->
    <GeometricCircle size={80} top="5%" left="-10%" color="var(--breeze-blue)" delay={0} duration={7} shape="diamond" rotation={15} />
    <GeometricCircle size={50} top="20%" right="-5%" color="var(--summer-pink)" delay={1.2} duration={6} shape="triangle" rotation={10} />

    <!-- Profile card -->
    <div
      class="mb-16 p-10 construct-corner"
      style="
        background: var(--bg-soft);
        border: 1px solid var(--border-light);
        position: relative;
        overflow: hidden;
      "
    >
      <!-- Dot grid decoration inside card -->
      <div class="absolute inset-0 opacity-30 pointer-events-none">
        <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <pattern id="about-dots" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
              <circle cx="10" cy="10" r="0.5" fill="var(--text-muted)" opacity="0.3" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#about-dots)" />
        </svg>
      </div>

      <!-- Diagonal accent behind avatar -->
      <div class="about-diagonal" aria-hidden="true"></div>

      <!-- Avatar placeholder -->
      <div class="relative flex flex-col md:flex-row items-start gap-8">
        <div
          class="shrink-0 flex items-center justify-center"
          style="
            width: 100px;
            height: 100px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--breeze-blue)33, var(--dust-purple)33);
            border: 1px solid var(--border-light);
          "
        >
          <svg width="40" height="40" viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="10" r="3" stroke="var(--night-blue)" stroke-width="1" />
            <path d="M5 26c0-4 3.5-6 7-6s7 2 7 6" stroke="var(--night-blue)" stroke-width="1" />
            <path d="M20 14c3 0 5 2 5 5s-2 5-5 5" stroke="var(--breeze-blue)" stroke-width="0.8" />
          </svg>
        </div>

        <div class="relative">
          <h1
            class="text-4xl font-bold mb-2"
            style="font-family: var(--font-serif); color: var(--text-primary);"
          >
            Starry Breeze
          </h1>
          <p
            class="text-sm tracking-wider mb-4"
            style="color: var(--text-muted); font-family: var(--font-sans);"
          >
            数字诗集 · 记录 · 观察
          </p>
          <hr class="construct-hr" />
        </div>
      </div>
    </div>

    <!-- Self introduction -->
    <section class="mb-16">
      <h2
        class="text-xl font-bold mb-6 tracking-wider"
        style="font-family: var(--font-sans); color: var(--text-primary); letter-spacing: 0.1em;"
      >
        关于
      </h2>
      <div style="font-family: var(--font-serif); color: var(--text-secondary); line-height: 2; font-size: 1.05rem;">
        <p>
          这只是一个安静的数字空间，用来存放一些文字、一些昼夜、一些被风吹散的念头。
        </p>
        <p>
          我相信文字应该像风一样自由，像星辰一样安静。
          这里是一片净土。
          你可以在任何时刻来到这里，像走进一间夏夜里亮着灯的房间，坐下来，听一首歌，读一段话。
        </p>
        <p>
          所有的文章都是写给未来自己的信。
          如果你碰巧读到，希望能为你带来一点宁静。
        </p>
      </div>
    </section>

    <!-- Social links -->
    <section>
      <h2
        class="text-xl font-bold mb-6 tracking-wider"
        style="font-family: var(--font-sans); color: var(--text-primary); letter-spacing: 0.1em;"
      >
        链接
      </h2>
      <div class="flex flex-wrap gap-6">
        <a
          href="https://github.com/SummeriseEscape"
          class="text-sm no-underline transition-colors duration-500"
          style="color: var(--text-secondary); font-family: var(--font-sans);"
        >
          GitHub
        </a>
        <a
          href="https://twitter.com/"
          class="text-sm no-underline transition-colors duration-500"
          style="color: var(--text-secondary); font-family: var(--font-sans);"
        >
          推特
        </a>
        <a
          href="https://www.zhihu.com/people/14-66-55-59"
          class="text-sm no-underline transition-colors duration-500"
          style="color: var(--text-secondary); font-family: var(--font-sans);"
        >
          知乎
        </a>
        <a
          href="3467328673@qq.com"
          class="text-sm no-underline transition-colors duration-500"
          style="color: var(--text-secondary); font-family: var(--font-sans);"
        >
          Email
        </a>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  .about-diagonal {
    position: absolute;
    top: -20%;
    right: -5%;
    width: 1px;
    height: 140%;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--breeze-blue) 20%,
      var(--deep-sky) 80%,
      transparent
    );
    transform: rotate(15deg);
    opacity: 0.1;
    pointer-events: none;
  }
</style>
