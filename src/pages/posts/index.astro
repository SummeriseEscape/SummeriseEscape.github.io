---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import PostCard from '@/components/post/PostCard.astro';
import ConstructDivider from '@/components/ui/ConstructDivider.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const sorted = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const categories = [
  { key: 'all', label: '全部' },
  { key: 'poetry', label: '诗歌' },
  { key: 'diary', label: '日记' },
  { key: 'essay', label: '散文' },
  { key: 'photography', label: '摄影' },
  { key: 'music', label: '音乐' },
];

// SSR / dev-mode category filter via query string
const selected = Astro.url.searchParams.get('category') || 'all';
const filtered = selected === 'all' ? sorted : sorted.filter((p) => p.data.category === selected);
---

<BaseLayout title="文章">
  <div
    class="posts-page"
    style="max-width: 1000px; margin-inline: auto; padding: 6rem 2rem 4rem;"
  >
    <h1
      class="text-4xl md:text-5xl font-bold mb-3"
      style="font-family: var(--font-serif); color: var(--text-primary);"
    >
      文章
    </h1>
    <p
      class="text-base mb-10"
      style="color: var(--text-secondary); font-family: var(--font-serif); font-style: italic;"
    >
      所有写成文字的夜晚
    </p>

    <!-- Category filters -->
    <div class="flex flex-wrap gap-4 mb-14" id="category-filters">
      {categories.map((cat) => (
        <a
          href={`/posts/${cat.key === 'all' ? '' : `?category=${cat.key}`}`}
          class="cat-link text-sm px-5 py-2.5 no-underline transition-all duration-500"
          data-category={cat.key}
          style={`
            font-family: var(--font-sans);
            font-size: 0.9rem;
            letter-spacing: 0.15em;
            color: ${cat.key === selected ? 'var(--bg-main)' : 'var(--text-secondary)'};
            background: ${cat.key === selected ? 'var(--night-blue)' : 'transparent'};
            border: 1px solid ${cat.key === selected ? 'var(--night-blue)' : 'var(--border-light)'};
            opacity: 0;
            transform: translateY(10px);
          `}
        >
          <span class="cat-label">{cat.label}</span>
          {cat.key === selected && <span class="cat-active-accent" aria-hidden="true"></span>}
        </a>
      ))}
    </div>

    <ConstructDivider variant="diamond" />

    <!-- Post grid -->
    <div
      id="post-grid"
      style="
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
        margin-top: 3rem;
      "
    >
      {sorted.map((post) => (
        <div class="post-card-wrapper" data-category={post.data.category}>
          <PostCard
            title={post.data.title}
            slug={post.id.replace(/\.(mdx|md)$/, '')}
            date={post.data.date}
            excerpt={post.data.excerpt}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
            mood={post.data.mood}
          />
        </div>
      ))}
    </div>
    <div id="empty-message" class="text-center py-20" style="display: none;">
      <p style="color: var(--text-muted); font-family: var(--font-sans);">
        该分类下暂无文章
      </p>
    </div>
  </div>
</BaseLayout>

<script>
  (() => {
    const wrappers = document.querySelectorAll<HTMLElement>('.post-card-wrapper');
    const links = document.querySelectorAll<HTMLAnchorElement>('.cat-link');
    const grid = document.getElementById('post-grid');
    const emptyMsg = document.getElementById('empty-message');

    function getActiveStyle() {
      return {
        color: 'var(--bg-main)',
        background: 'var(--night-blue)',
        borderColor: 'var(--night-blue)',
      };
    }
    function getInactiveStyle() {
      return {
        color: 'var(--text-secondary)',
        background: 'transparent',
        borderColor: 'var(--border-light)',
      };
    }

    function applyCategory(cat: string) {
      let count = 0;
      wrappers.forEach((w) => {
        const match = cat === 'all' || w.dataset.category === cat;
        w.style.display = match ? '' : 'none';
        if (match) count++;
      });

      if (grid && emptyMsg) {
        grid.style.display = count > 0 ? '' : 'none';
        (emptyMsg as HTMLElement).style.display = count === 0 ? '' : 'none';
      }

      links.forEach((a) => {
        const isActive = a.dataset.category === cat;
        const s = isActive ? getActiveStyle() : getInactiveStyle();
        a.style.color = s.color;
        a.style.background = s.background;
        a.style.borderColor = s.borderColor;

        // Toggle active accent
        const existing = a.querySelector('.cat-active-accent');
        if (isActive && !existing) {
          const accent = document.createElement('span');
          accent.className = 'cat-active-accent';
          accent.setAttribute('aria-hidden', 'true');
          a.appendChild(accent);
        } else if (!isActive && existing) {
          existing.remove();
        }
      });
    }

    // Stagger entrance for category links
    const catLinks = document.querySelectorAll<HTMLElement>('.cat-link');
    catLinks.forEach((link, i) => {
      setTimeout(() => {
        link.style.transition = 'opacity 0.5s ease, transform 0.5s ease, color 0.4s ease, background 0.4s ease, border-color 0.4s ease';
        link.style.opacity = '1';
        link.style.transform = 'translateY(0)';
      }, 100 + i * 80);
    });

    // Handle category link clicks
    links.forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault();
        const cat = a.dataset.category!;
        const url = cat === 'all' ? '/posts/' : `/posts/?category=${cat}`;
        history.pushState({ category: cat }, '', url);
        applyCategory(cat);
      });
    });

    // Handle back/forward
    window.addEventListener('popstate', (e) => {
      const cat = e.state?.category || new URLSearchParams(location.search).get('category') || 'all';
      applyCategory(cat);
    });

    // Initialize from URL on load
    const initialCat = new URLSearchParams(location.search).get('category') || 'all';
    if (initialCat !== 'all') {
      applyCategory(initialCat);
    }
  })();
</script>
