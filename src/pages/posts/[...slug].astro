---
import { getCollection } from 'astro:content';
import BaseLayout from '@/components/layout/BaseLayout.astro';
import PostLayout from '@/components/post/PostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.(mdx|md)$/, '') },
    props: { post },
  }));
}

interface Props {
  post: Awaited<ReturnType<typeof getCollection<'posts'>>>[number];
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout title={post.data.title} description={post.data.excerpt} image={post.data.image}>
  <PostLayout post={post}>
    <Content />
  </PostLayout>
</BaseLayout>
