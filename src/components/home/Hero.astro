---
import Starfield from '@/components/ui/Starfield.astro';
import GeometricCircle from '@/components/ui/GeometricCircle.astro';
import VerticalText from '@/components/ui/VerticalText.astro';
import ScrollIndicator from '@/components/ui/ScrollIndicator.astro';
---

<section
  class="hero relative flex items-center justify-center overflow-hidden construct-diagonal"
  style="min-height: 100vh;"
>

  <!-- Starfield background -->
  <Starfield />

  <!-- Geometric decorations -->
  <GeometricCircle size={180} top="12%" left="8%" color="var(--breeze-blue)" delay={0} duration={7} />
  <GeometricCircle size={90} top="25%" right="12%" color="var(--summer-pink)" delay={1.5} duration={6} shape="diamond" rotation={15} />
  <GeometricCircle size={140} bottom="20%" left="15%" color="var(--dust-purple)" delay={0.8} duration={8} />
  <GeometricCircle size={60} top="60%" right="8%" color="var(--moon-beige)" delay={2.2} duration={5.5} shape="triangle" rotation={10} />
  <GeometricCircle size={100} bottom="30%" right="25%" color="var(--breeze-blue)" delay={3} duration={7.5} />

  <!-- Main content -->
  <div class="relative text-center construct-corner" style="z-index: 2;">
    <h1
      id="hero-title"
      class="font-bold m-0 tracking-wide"
      style="
        font-family: var(--font-serif);
        font-size: clamp(4rem, 10vw, 9rem);
        color: var(--night-blue);
        line-height: 1.1;
        letter-spacing: 0.05em;
      "
    >
      风辰
    </h1>
    <p
      id="hero-tagline"
      class="mt-6 m-0"
      style="
        font-family: var(--font-serif);
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: var(--text-secondary);
        font-style: italic;
        letter-spacing: 0.1em;
      "
    >
      风吹过夏夜星辰
    </p>
  </div>

  <!-- Vertical text decoration -->
  <div class="absolute right-10 top-1/2" style="z-index: 2; transform: translateY(-50%);">
    <VerticalText text="夏の夜の風" />
  </div>

  <div class="absolute left-6 bottom-1/3" style="z-index: 2;">
    <VerticalText text="星空の下で" />
  </div>

  <!-- Scroll indicator -->
  <ScrollIndicator />
</section>
