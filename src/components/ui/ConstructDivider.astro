---
interface Props {
  variant?: 'line' | 'diamond' | 'corner';
  class?: string;
}

const { variant = 'line', class: className } = Astro.props;
---

{
  variant === 'line' ? (
    <hr class:list={['construct-hr', className]} />
  ) : variant === 'diamond' ? (
    <div class:list={['flex items-center gap-3 my-8', className]} role="separator" aria-hidden="true">
      <span class="flex-1 h-px" style="background: linear-gradient(to right, transparent, var(--border-light));" />
      <span class="text-[6px]" style="color: var(--breeze-blue); opacity: 0.4;">◆</span>
      <span class="flex-1 h-px" style="background: linear-gradient(to left, transparent, var(--border-light));" />
    </div>
  ) : (
    <div class:list={['flex items-center gap-4 my-8', className]} role="separator" aria-hidden="true">
      <span class="w-3 h-3 border-t border-l" style="border-color: var(--breeze-blue); opacity: 0.25;" />
      <span class="flex-1 h-px" style="background: linear-gradient(to right, var(--border-light), var(--border-light) 40%, var(--breeze-blue) 60%, var(--border-light));" />
      <span class="w-3 h-3 border-b border-r" style="border-color: var(--breeze-blue); opacity: 0.25;" />
    </div>
  )
}
