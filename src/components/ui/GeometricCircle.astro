---
interface Props {
  size?: number;
  top?: string;
  left?: string;
  right?: string;
  bottom?: string;
  color?: string;
  delay?: number;
  duration?: number;
  blur?: number;
  shape?: 'circle' | 'triangle' | 'diamond' | 'rect';
  rotation?: number;
}

const {
  size = 120,
  top,
  left,
  right,
  bottom,
  color = 'var(--breeze-blue)',
  delay = 0,
  duration = 7,
  blur = 0,
  shape = 'circle',
  rotation = 0,
} = Astro.props;

const clipPaths: Record<string, string> = {
  circle: 'none',
  triangle: 'polygon(50% 0%, 0% 100%, 100% 100%)',
  diamond: 'polygon(50% 0%, 100% 50%, 50% 100%, 0% 50%)',
  rect: 'none',
};

const borderRadii: Record<string, string> = {
  circle: '50%',
  triangle: '0',
  diamond: '0',
  rect: '2px',
};
---

<div
  class="geometric-circle absolute pointer-events-none"
  style={{
    width: `${size}px`,
    height: `${size}px`,
    top: top ?? 'auto',
    left: left ?? 'auto',
    right: right ?? 'auto',
    bottom: bottom ?? 'auto',
    borderRadius: borderRadii[shape],
    clipPath: clipPaths[shape],
    background: `radial-gradient(circle at 40% 40%, ${color}22, ${color}08)`,
    border: `1px solid ${color}18`,
    animation: `float ${duration}s ease-in-out ${delay}s infinite`,
    filter: blur > 0 ? `blur(${blur}px)` : 'none',
    transform: rotation !== 0 ? `rotate(${rotation}deg)` : undefined,
    zIndex: 1,
  }}
></div>
